{
  "name": "luma-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cf:migrate:brand": "dotenv -e .env.local -- bash -lc 'contentful space migration -s \"$CONTENTFUL_SPACE_ID\" -e \"$CONTENTFUL_ENVIRONMENT\" --mt \"$CONTENTFUL_MANAGEMENT_TOKEN\" ./migrations/001-create-brand.js'",
    "cf:migrate:camera": "dotenv -e .env.local -- bash -lc 'contentful space migration -s \"$CONTENTFUL_SPACE_ID\" -e \"$CONTENTFUL_ENVIRONMENT\" --mt \"$CONTENTFUL_MANAGEMENT_TOKEN\" ./migrations/002-create-camera.js'",
    "cf:import": "dotenv -e .env.local -- tsx scripts/migrate/run.ts"
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "contentful": "^11.11.0",
    "contentful-cli": "^3.10.4",
    "contentful-management": "^11.74.0",
    "contentful-migration": "^4.32.0",
    "dotenv": "^17.3.1",
    "fast-csv": "^5.0.5",
    "gray-matter": "^4.0.3",
    "mime-types": "^3.0.2",
    "next": "16.2.0",
    "p-limit": "^7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "slugify": "^1.6.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
